# Copy this file to .env and fill in the values below.
#   cp .env.example .env

# Port the API listens on. Avoid 5000 on macOS — AirPlay Receiver squats on it.
PORT=5050

# Local MongoDB:
MONGO_URI=mongodb://127.0.0.1:27017/food-saver
# Or MongoDB Atlas (get this from Atlas → Connect → Compass/Driver):
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/food-saver?retryWrites=true&w=majority

# Any long random string — used to sign auth tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Optional — powers the AI listing assistant (auto category/allergens/description).
# Get a free key at https://aistudio.google.com/apikey (starts with "AIzaSy...").
# Leave blank to run without it; donations are created normally either way.
GEMINI_API_KEY=

# Must match the URL the frontend runs on, for CORS.
CLIENT_ORIGIN=http://localhost:5173

# Cloudinary — stores donation/pickup photos so they survive redeploys on
# platforms with ephemeral disks (e.g. Render). Free tier at cloudinary.com;
# all three values are on your dashboard home page (API Secret needs "reveal").
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
